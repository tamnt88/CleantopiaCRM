@model List<CleantopiaCRM.Web.Entities.ServiceUnit>
@{
    ViewData["Title"] = "Đơn vị tính";
    ViewData["BreadcrumbParent"] = "Bảng giá dịch vụ";
    ViewData["BreadcrumbParentUrl"] = "/ServicePrices";
}
<link rel="stylesheet" href="~/lib/datatables/css/dataTables.bootstrap5.min.css" />
<style>
    .status-tag {
        display: inline-block;
        padding: 3px 10px;
        font-size: 12px;
        font-weight: 400;
        border: 0;
        border-radius: 999px;
        line-height: 1.1;
    }

    .status-active {
        color: #fff;
        background: #2ea44f;
    }

    .status-inactive {
        color: #fff;
        background: #6c757d;
    }

    .dataTables_wrapper .pagination {
        gap: 0 !important;
    }

    .dataTables_wrapper .pagination .page-item {
        margin: 0 !important;
    }

    .dataTables_wrapper .pagination .page-link {
        border-radius: 0 !important;
        min-width: 30px;
        padding: .28rem .5rem;
        font-size: 13px;
        margin-left: 0 !important;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Đơn vị tính</h4>
    <button class="btn btn-brand" data-bs-toggle="modal" data-bs-target="#createUnitModal">
        <i class="fa-solid fa-plus"></i> Thêm đơn vị
    </button>
</div>

<div class="table-responsive">
    <table id="serviceUnitTable" class="table table-striped table-bordered align-middle w-100">
        <thead class="table-light">
            <tr>
                <th style="width:60px">#</th>
                <th>Tên đơn vị</th>
                <th style="width:140px">Trạng thái</th>
                <th style="width:130px">Thao tác</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr><td colspan="4" class="text-center text-muted py-4">Chưa có đơn vị tính.</td></tr>
        }
        else
        {
            var idx = 1;
            foreach (var x in Model)
            {
                <tr>
                    <td>@idx</td>
                    <td>@x.Name</td>
                    <td>
                        @if (x.IsActive)
                        {
                            <span class="status-tag status-active">Áp dụng</span>
                        }
                        else
                        {
                            <span class="status-tag status-inactive">Ngưng</span>
                        }
                    </td>
                    <td class="text-end">
                        <button type="button" class="btn btn-sm btn-outline-primary js-edit-unit"
                                data-id="@x.Id" data-name="@x.Name" data-active="@x.IsActive">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-danger js-delete-unit"
                                data-id="@x.Id" data-name="@x.Name">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>
                idx++;
            }
        }
        </tbody>
    </table>
</div>

<div class="modal fade" id="createUnitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="/ServiceUnits/Create">
                <div class="modal-header">
                    <h5 class="modal-title">Thêm đơn vị tính</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Tên đơn vị</label>
                        <input name="name" class="form-control" placeholder="Ví dụ: Gói" required />
                    </div>
                    <div>
                        <label class="form-label">Trạng thái</label>
                        <select name="isActive" class="form-select">
                            <option value="true">Áp dụng</option>
                            <option value="false">Ngưng</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-brand">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editUnitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="/ServiceUnits/Update">
                <input type="hidden" name="id" id="editUnitId" />
                <div class="modal-header">
                    <h5 class="modal-title">Cập nhật đơn vị tính</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Tên đơn vị</label>
                        <input name="name" id="editUnitName" class="form-control" required />
                    </div>
                    <div>
                        <label class="form-label">Trạng thái</label>
                        <select name="isActive" id="editUnitActive" class="form-select">
                            <option value="true">Áp dụng</option>
                            <option value="false">Ngưng</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-brand">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteUnitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="/ServiceUnits/Delete">
                <input type="hidden" name="id" id="deleteUnitId" />
                <div class="modal-header">
                    <h5 class="modal-title text-danger">Xóa đơn vị tính</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Bạn có chắc muốn xóa đơn vị <strong id="deleteUnitName"></strong>?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts{
<script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
<script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
<script>
(function(){
    $('#serviceUnitTable').DataTable({
        pageLength: 20,
        lengthChange: false,
        dom: "t<'d-flex justify-content-end mt-2'p>",
        pagingType: 'full_numbers',
        order: [[0, 'asc']],
        language: {
            info: 'Hiển thị _START_ đến _END_ trong _TOTAL_ đơn vị',
            infoEmpty: 'Không có dữ liệu',
            zeroRecords: 'Không tìm thấy dữ liệu phù hợp',
            paginate: { first: '«', last: '»', next: '›', previous: '‹' }
        },
        columnDefs: [{ targets: 3, orderable: false, searchable: false }]
    });

    const editModal = new bootstrap.Modal(document.getElementById('editUnitModal'));
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteUnitModal'));

    document.querySelectorAll('.js-edit-unit').forEach(function(btn){
        btn.addEventListener('click', function(){
            document.getElementById('editUnitId').value = this.dataset.id || '';
            document.getElementById('editUnitName').value = this.dataset.name || '';
            document.getElementById('editUnitActive').value = this.dataset.active === 'True' ? 'true' : 'false';
            editModal.show();
        });
    });

    document.querySelectorAll('.js-delete-unit').forEach(function(btn){
        btn.addEventListener('click', function(){
            document.getElementById('deleteUnitId').value = this.dataset.id || '';
            document.getElementById('deleteUnitName').textContent = this.dataset.name || '';
            deleteModal.show();
        });
    });
})();
</script>
}
