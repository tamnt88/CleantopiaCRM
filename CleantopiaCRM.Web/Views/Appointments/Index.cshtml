@model CleantopiaCRM.Web.Models.Common.PagedResult<CleantopiaCRM.Web.Entities.Appointment>
@{
    ViewData["Title"] = "Lịch hẹn";
    var customers = ViewBag.Customers as List<CleantopiaCRM.Web.Entities.Customer> ?? new();
    var types = ViewBag.Types as List<string> ?? new();
    var route = new Dictionary<string, string?>();
    foreach (var key in Context.Request.Query.Keys)
    {
        if (!string.Equals(key, "page", StringComparison.OrdinalIgnoreCase)) route[key] = Context.Request.Query[key].ToString();
    }
}
<div class="d-flex justify-content-between align-items-center mb-3"><h4 class="mb-0">Lịch hẹn</h4><a href="/Appointments/Create" class="btn btn-brand"><i class="fa-solid fa-plus"></i> Thêm lịch</a></div>
<form method="get" class="card card-body mb-3"><div class="row g-2"><div class="col-md-3"><input name="q" value="@Model.Query" class="form-control" placeholder="Khách hàng" /></div><div class="col-md-2"><select name="type" class="form-select"><option value="">-- Loại lịch --</option>@foreach(var t in types){<option value="@t" selected="@(t==(string?)ViewBag.Type)">@t</option>}</select></div><div class="col-md-3"><select name="customerId" class="form-select"><option value="">-- Khách hàng --</option>@foreach(var c in customers){<option value="@c.Id" selected="@(c.Id==(int?)ViewBag.CustomerId)">@c.Name</option>}</select></div><div class="col-md-2"><select name="status" class="form-select"><option value="">-- Trạng thái --</option><option selected="@("Planned"==(string?)ViewBag.Status)">Planned</option><option selected="@("Done"==(string?)ViewBag.Status)">Done</option><option selected="@("Cancelled"==(string?)ViewBag.Status)">Cancelled</option></select></div><div class="col-md-1"><input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" /></div><div class="col-md-1"><input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" /></div><div class="col-md-12 d-flex gap-2"><button class="btn btn-primary"><i class="fa-solid fa-filter"></i> Lọc</button><a class="btn btn-outline-secondary" href="/Appointments"><i class="fa-solid fa-rotate-left"></i> Đặt lại</a></div></div></form>
<div class="table-responsive"><table class="table table-striped table-bordered align-middle"><thead class="table-light"><tr><th>Khách hàng</th><th>Thời gian</th><th>Loại</th><th>Trạng thái</th><th style="width:160px">Thao tác</th></tr></thead><tbody>@foreach(var x in Model.Items){<tr><td>@x.Customer?.Name</td><td>@x.ScheduledAt.ToString("dd/MM/yyyy HH:mm")</td><td>@x.Type</td><td>@x.Status</td><td><a href="/Appointments/Edit/@x.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square"></i></a> <form method="post" action="/Appointments/Delete/@x.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa lịch hẹn?')"><i class="fa-solid fa-trash"></i></button></form></td></tr>}</tbody></table></div>
@if (Model.TotalPages > 1){<nav><ul class="pagination">@for (var i = 1; i <= Model.TotalPages; i++){<li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-all-route-data="route" asp-route-page="@i">@i</a></li>}</ul></nav>}
