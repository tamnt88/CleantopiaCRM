@model CleantopiaCRM.Web.Models.Common.PagedResult<CleantopiaCRM.Web.Entities.Assignment>
@{
    ViewData["Title"] = "Phân công";
    var employees = ViewBag.Employees as List<CleantopiaCRM.Web.Entities.Employee> ?? new();
    var roles = ViewBag.Roles as List<string> ?? new();
    var route = new Dictionary<string, string?>();
    foreach (var key in Context.Request.Query.Keys)
    {
        if (!string.Equals(key, "page", StringComparison.OrdinalIgnoreCase)) route[key] = Context.Request.Query[key].ToString();
    }
}
<div class="d-flex justify-content-between align-items-center mb-3"><h4 class="mb-0">Phân công nhân sự</h4><a href="/Assignments/Create" class="btn btn-brand"><i class="fa-solid fa-plus"></i> Phân công mới</a></div>
<form method="get" class="card card-body mb-3"><div class="row g-2"><div class="col-md-3"><input name="q" value="@Model.Query" class="form-control" placeholder="Tên NV / khách hàng" /></div><div class="col-md-3"><select name="employeeId" class="form-select"><option value="">-- Nhân viên --</option>@foreach(var e in employees){<option value="@e.Id" selected="@(e.Id==(int?)ViewBag.EmployeeId)">@e.FullName</option>}</select></div><div class="col-md-2"><select name="role" class="form-select"><option value="">-- Vai trò --</option>@foreach(var r in roles){<option value="@r" selected="@(r==(string?)ViewBag.Role)">@r</option>}</select></div><div class="col-md-2"><input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" /></div><div class="col-md-2"><input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" /></div><div class="col-md-12 d-flex gap-2"><button class="btn btn-primary"><i class="fa-solid fa-filter"></i> Lọc</button><a class="btn btn-outline-secondary" href="/Assignments"><i class="fa-solid fa-rotate-left"></i> Đặt lại</a></div></div></form>
<div class="table-responsive"><table class="table table-striped table-bordered align-middle"><thead class="table-light"><tr><th>Lịch hẹn</th><th>Nhân viên</th><th>Vai trò</th><th style="width:160px">Thao tác</th></tr></thead><tbody>@foreach(var x in Model.Items){<tr><td>@x.Appointment?.Customer?.Name - @x.Appointment?.ScheduledAt.ToString("dd/MM HH:mm")</td><td>@x.Employee?.FullName</td><td>@x.Role</td><td><a href="/Assignments/Edit/@x.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square"></i></a> <form method="post" action="/Assignments/Delete/@x.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa phân công?')"><i class="fa-solid fa-trash"></i></button></form></td></tr>}</tbody></table></div>
@if (Model.TotalPages > 1){<nav><ul class="pagination">@for (var i = 1; i <= Model.TotalPages; i++){<li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-all-route-data="route" asp-route-page="@i">@i</a></li>}</ul></nav>}
