@model CleantopiaCRM.Web.ViewModels.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập CRM</title>
    <link rel="icon" type="image/jpeg" href="~/images/fav.jpg" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">
    <div class="login-overlay"></div>
    <main class="login-wrap">
        <section class="login-glass">
            <div class="text-center mb-4">
                <img src="~/images/logo.png" class="login-logo" alt="Clean Topia" />
                <h1 class="login-title">Đăng nhập CRM</h1>
            </div>

            <form method="post" autocomplete="off">
                <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                <div class="login-field">
                    <input asp-for="Username" class="form-control login-input" placeholder="Nhập tài khoản" />
                </div>
                <div class="login-field">
                    <input asp-for="Password" type="password" class="form-control login-input" placeholder="Nhập mật khẩu" />
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4 text-white-50 small">
                    <label class="m-0 d-flex align-items-center gap-2">
                        <input type="checkbox" /> Ghi nhớ
                    </label>
                    <span>Quên mật khẩu?</span>
                </div>

                <button class="btn login-btn w-100" type="submit">Đăng nhập</button>
            </form>

            <div class="small text-center text-white-50 mt-4">Mặc định: admin / admin123</div>
        </section>
    </main>
</body>
</html>
