@model CleantopiaCRM.Web.ViewModels.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập CRM</title>
    <link rel="icon" type="image/jpeg" href="~/images/fav.jpg" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">
    <main class="login-wrap">
        <section class="login-shell">
            <div class="login-brand text-center mb-3">
                <img src="~/images/logo.png" class="login-logo" alt="Clean Topia" />
            </div>
            <section class="login-card">
                <h1 class="login-title">Đăng nhập tài khoản</h1>
                <p class="login-subtitle">Nhập tài khoản và mật khẩu để tiếp tục</p>

                <form method="post" autocomplete="off">
                    <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                    <div class="login-field">
                        <label asp-for="Username" class="login-label">Tài khoản <span>*</span></label>
                        <input asp-for="Username" class="form-control login-input" placeholder="Nhập tài khoản" />
                    </div>
                    <div class="login-field">
                        <label asp-for="Password" class="login-label">Mật khẩu <span>*</span></label>
                        <input asp-for="Password" type="password" class="form-control login-input" placeholder="Nhập mật khẩu" />
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3 login-helper">
                        <label class="m-0 d-flex align-items-center gap-2">
                            <input type="checkbox" /> Ghi nhớ mật khẩu
                        </label>
                        <span class="login-link">Quên mật khẩu?</span>
                    </div>

                    <button class="btn login-btn" type="submit">Đăng nhập</button>
                </form>

                <div class="small text-center login-note mt-3">Mặc định: admin / admin123</div>
            </section>
        </section>
    </main>
</body>
</html>
