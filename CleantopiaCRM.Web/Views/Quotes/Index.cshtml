@model CleantopiaCRM.Web.Models.Common.PagedResult<CleantopiaCRM.Web.Entities.Quote>
@{
    ViewData["Title"] = "Báo giá";
    var customers = ViewBag.Customers as List<CleantopiaCRM.Web.Entities.Customer> ?? new();
    var route = new Dictionary<string, string?>();
    foreach (var key in Context.Request.Query.Keys)
    {
        if (!string.Equals(key, "page", StringComparison.OrdinalIgnoreCase)) route[key] = Context.Request.Query[key].ToString();
    }
}
<div class="d-flex justify-content-between align-items-center mb-3"><h4 class="mb-0">Báo giá</h4><a href="/Quotes/Create" class="btn btn-brand"><i class="fa-solid fa-plus"></i> Tạo báo giá</a></div>
<form method="get" class="card card-body mb-3"><div class="row g-2"><div class="col-md-3"><input name="q" value="@Model.Query" class="form-control" placeholder="Mã báo giá" /></div><div class="col-md-3"><select name="customerId" class="form-select"><option value="">-- Khách hàng --</option>@foreach(var c in customers){<option value="@c.Id" selected="@(c.Id==(int?)ViewBag.CustomerId)">@c.Name</option>}</select></div><div class="col-md-2"><select name="status" class="form-select"><option value="">-- Trạng thái --</option><option selected="@("Draft"==(string?)ViewBag.Status)">Draft</option><option selected="@("Approved"==(string?)ViewBag.Status)">Approved</option></select></div><div class="col-md-2"><input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" /></div><div class="col-md-2"><input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" /></div><div class="col-md-12 d-flex gap-2"><button class="btn btn-primary"><i class="fa-solid fa-filter"></i> Lọc</button><a class="btn btn-outline-secondary" href="/Quotes"><i class="fa-solid fa-rotate-left"></i> Đặt lại</a></div></div></form>
<div class="table-responsive"><table class="table table-striped table-bordered align-middle"><thead class="table-light"><tr><th>Số</th><th>Khách hàng</th><th>Ngày</th><th>Trạng thái</th><th style="width:260px">Thao tác</th></tr></thead><tbody>@foreach(var q in Model.Items){<tr><td>@q.QuoteNo</td><td>@q.Customer?.Name</td><td>@q.QuoteDate.ToString("dd/MM/yyyy")</td><td>@q.Status</td><td><a href="/Quotes/Edit/@q.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square"></i></a> <a href="/Quotes/Approve/@q.Id" class="btn btn-sm btn-outline-success"><i class="fa-solid fa-check"></i></a> <a href="/Quotes/ExportPdf/@q.Id" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-file-pdf"></i></a> <a href="/Quotes/ExportExcel/@q.Id" class="btn btn-sm btn-outline-success"><i class="fa-solid fa-file-excel"></i></a> <form method="post" action="/Quotes/Delete/@q.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa báo giá?')"><i class="fa-solid fa-trash"></i></button></form></td></tr>}</tbody></table></div>
@if (Model.TotalPages > 1){<nav><ul class="pagination">@for (var i = 1; i <= Model.TotalPages; i++){<li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-all-route-data="route" asp-route-page="@i">@i</a></li>}</ul></nav>}
