@model CleantopiaCRM.Web.ViewModels.DashboardVm
@{
    ViewData["Title"] = "Dashboard";
}

<div class="dash-wrap">
    <div class="dash-header">Tổng quan</div>

    <div class="dash-kpi-grid">
        <div class="dash-kpi kpi-1">
            <div class="kpi-title">Tổng khách hàng</div>
            <div class="kpi-value">@Model.CustomerCount</div>
        </div>
        <div class="dash-kpi kpi-2">
            <div class="kpi-title">Lịch hẹn hôm nay</div>
            <div class="kpi-value">@Model.AppointmentToday</div>
        </div>
        <div class="dash-kpi kpi-3">
            <div class="kpi-title">Doanh thu</div>
            <div class="kpi-value">@Model.Revenue.ToString("N0")</div>
        </div>
        <div class="dash-kpi kpi-4">
            <div class="kpi-title">KH mới tháng này</div>
            <div class="kpi-value">@Model.NewCustomersThisMonth</div>
        </div>
        <div class="dash-kpi kpi-5">
            <div class="kpi-title">Nhắc bảo trì</div>
            <div class="kpi-value">@Model.PendingReminders</div>
        </div>
    </div>
</div>
