@model CleantopiaCRM.Web.Models.Common.PagedResult<CleantopiaCRM.Web.Entities.AppUser>
<h4>Tài kho?n ngu?i dùng <a href="/Users/Create" class="btn btn-sm btn-brand">T?o user</a></h4>
<form class="row g-2 mb-3"><div class="col-md-4"><input name="q" value="@Model.Query" class="form-control" placeholder="T́m user" /></div><div class="col-md-2"><button class="btn btn-outline-primary">T́m</button></div></form>
<table class="table"><tr><th>Username</th><th>H? tên</th><th>Vai tṛ</th><th>Nhân viên</th><th></th></tr>@foreach(var x in Model.Items){<tr><td>@x.Username</td><td>@x.FullName</td><td>@x.Role</td><td>@x.Employee?.FullName</td><td><a href="/Users/Edit/@x.Id" class="btn btn-sm btn-outline-primary">S?a</a> <form class="d-inline" method="post" action="/Users/Delete/@x.Id"><button class="btn btn-sm btn-outline-danger">Xóa</button></form><form class="d-inline" method="post" action="/Users/ResetPassword"><input type="hidden" name="id" value="@x.Id"/><input type="hidden" name="newPassword" value="123456"/><button class="btn btn-sm btn-outline-warning">Reset 123456</button></form></td></tr>}</table>
