@model CleantopiaCRM.Web.Models.Common.PagedResult<CleantopiaCRM.Web.Entities.ServicePrice>
@{
    ViewData["Title"] = "Bảng giá dịch vụ";
    var categories = ViewBag.Categories as List<string> ?? new();
    var route = new Dictionary<string, string?>();
    foreach (var key in Context.Request.Query.Keys)
    {
        if (!string.Equals(key, "page", StringComparison.OrdinalIgnoreCase)) route[key] = Context.Request.Query[key].ToString();
    }
}
<div class="d-flex justify-content-between align-items-center mb-3"><h4 class="mb-0">Bảng giá dịch vụ</h4><a href="/ServicePrices/Create" class="btn btn-brand"><i class="fa-solid fa-plus"></i> Thêm</a></div>
<form method="get" class="card card-body mb-3"><div class="row g-2"><div class="col-md-3"><input name="q" value="@Model.Query" class="form-control" placeholder="Tên dịch vụ" /></div><div class="col-md-3"><select name="category" class="form-select"><option value="">-- Nhóm dịch vụ --</option>@foreach(var c in categories){<option value="@c" selected="@(c==(string?)ViewBag.Category)">@c</option>}</select></div><div class="col-md-2"><input type="number" min="0" name="minPrice" value="@ViewBag.MinPrice" class="form-control" placeholder="Giá từ" /></div><div class="col-md-2"><input type="number" min="0" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control" placeholder="Giá đến" /></div><div class="col-md-2"><select name="isActive" class="form-select"><option value="">-- Trạng thái --</option><option value="true" selected="@("true"==(string?)ViewBag.IsActive)">Áp dụng</option><option value="false" selected="@("false"==(string?)ViewBag.IsActive)">Ngưng</option></select></div><div class="col-md-12 d-flex gap-2"><button class="btn btn-primary"><i class="fa-solid fa-filter"></i> Lọc</button><a class="btn btn-outline-secondary" href="/ServicePrices"><i class="fa-solid fa-rotate-left"></i> Đặt lại</a></div></div></form>
<div class="table-responsive"><table class="table table-striped table-bordered align-middle"><thead class="table-light"><tr><th>Nhóm</th><th>Dịch vụ</th><th>Biến thể</th><th>Giá</th><th>Trạng thái</th><th style="width:160px">Thao tác</th></tr></thead><tbody>@foreach(var x in Model.Items){<tr><td>@x.Category</td><td>@x.ServiceName</td><td>@x.VariantName</td><td>@x.Price.ToString("N0")</td><td>@(x.IsActive ? "Áp dụng" : "Ngưng")</td><td><a href="/ServicePrices/Edit/@x.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square"></i></a> <form method="post" action="/ServicePrices/Delete/@x.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa dịch vụ?')"><i class="fa-solid fa-trash"></i></button></form></td></tr>}</tbody></table></div>
@if (Model.TotalPages > 1){<nav><ul class="pagination">@for (var i = 1; i <= Model.TotalPages; i++){<li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-all-route-data="route" asp-route-page="@i">@i</a></li>}</ul></nav>}
