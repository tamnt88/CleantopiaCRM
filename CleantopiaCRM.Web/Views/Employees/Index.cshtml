@model CleantopiaCRM.Web.Models.Common.PagedResult<CleantopiaCRM.Web.Entities.Employee>
@{
    ViewData["Title"] = "Nhân viên";
    var route = new Dictionary<string, string?>();
    foreach (var key in Context.Request.Query.Keys)
    {
        if (!string.Equals(key, "page", StringComparison.OrdinalIgnoreCase)) route[key] = Context.Request.Query[key].ToString();
    }
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Nhân viên</h4>
    <a href="/Employees/Create" class="btn btn-brand"><i class="fa-solid fa-plus"></i> Thêm</a>
</div>
<form method="get" class="card card-body mb-3">
    <div class="row g-2">
        <div class="col-md-4"><input name="q" value="@Model.Query" class="form-control" placeholder="Tên / Mã / SĐT" /></div>
        <div class="col-md-3"><select name="role" class="form-select"><option value="">-- Vai trò --</option><option selected="@("KyThuat"==(string?)ViewBag.Role)">KyThuat</option><option selected="@("GiamSat"==(string?)ViewBag.Role)">GiamSat</option><option selected="@("DieuPhoi"==(string?)ViewBag.Role)">DieuPhoi</option><option selected="@("Admin"==(string?)ViewBag.Role)">Admin</option></select></div>
        <div class="col-md-3"><select name="isActive" class="form-select"><option value="">-- Trạng thái --</option><option value="true" selected="@("true"==(string?)ViewBag.IsActive)">Đang làm</option><option value="false" selected="@("false"==(string?)ViewBag.IsActive)">Ngưng</option></select></div>
        <div class="col-md-2 d-flex gap-2"><button class="btn btn-primary w-100"><i class="fa-solid fa-filter"></i> Lọc</button><a class="btn btn-outline-secondary" href="/Employees"><i class="fa-solid fa-rotate-left"></i></a></div>
    </div>
</form>
<div class="table-responsive"><table class="table table-striped table-bordered align-middle"><thead class="table-light"><tr><th>Mã</th><th>Tên</th><th>Vai trò</th><th>SĐT</th><th>Địa chỉ</th><th style="width:160px">Thao tác</th></tr></thead><tbody>@foreach (var x in Model.Items){<tr><td>@x.EmployeeCode</td><td>@x.FullName</td><td>@x.Role</td><td>@x.Phone</td><td>@x.Address?.FullText</td><td><a href="/Employees/Edit/@x.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square"></i></a> <form method="post" action="/Employees/Delete/@x.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa nhân viên?')"><i class="fa-solid fa-trash"></i></button></form></td></tr>}</tbody></table></div>
@if (Model.TotalPages > 1){<nav><ul class="pagination">@for (var i = 1; i <= Model.TotalPages; i++){<li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-all-route-data="route" asp-route-page="@i">@i</a></li>}</ul></nav>}
