@model CleantopiaCRM.Web.Entities.Employee
@{ var provinces = (IEnumerable<CleantopiaCRM.Web.Entities.GhnProvince>)ViewBag.Provinces; var wards = (IEnumerable<CleantopiaCRM.Web.Entities.GhnWard>)ViewBag.Wards; }
<h4>Nh‚n viÍn</h4>
<form method="post" class="row g-2">
<div class="col-md-3"><input asp-for="EmployeeCode" class="form-control" placeholder="M„ NV" /></div>
<div class="col-md-5"><input asp-for="FullName" class="form-control" placeholder="H? tÍn" /></div>
<div class="col-md-4"><input asp-for="Phone" class="form-control" placeholder="S–T" /></div>
<div class="col-md-4"><input asp-for="Email" class="form-control" placeholder="Email" /></div>
<div class="col-md-4"><select class="form-select" asp-for="Role"><option>Admin</option><option>DieuPhoi</option><option>KyThuat</option><option>GiamSat</option></select></div>
<div class="col-md-4"><select class="form-select" asp-for="IsActive"><option value="true">–ang ho?t d?ng</option><option value="false">Ngung</option></select></div>
<div class="col-md-2"><input class="form-control" name="houseNumber" value="@Model.Address?.HouseNumber" placeholder="S? nh‡" /></div>
<div class="col-md-4"><input class="form-control" name="street" value="@Model.Address?.Street" placeholder="TÍn du?ng" /></div>
<div class="col-md-3"><select class="form-select" id="provinceId" name="provinceId">@foreach(var p in provinces){<option value="@p.Id">@p.ProvinceName</option>}</select></div>
<div class="col-md-3"><select class="form-select" id="wardId" name="wardId">@foreach(var w in wards){<option value="@w.Id">@w.WardName</option>}</select></div>
<div class="col-12"><button class="btn btn-brand">Luu</button></div>
</form>

@section Scripts {
<script>
(function(){
  const province = document.getElementById('provinceId');
  const ward = document.getElementById('wardId');
  async function loadWards(){
    const res = await fetch(`/api/address/wards?provinceId=${province.value}`);
    const data = await res.json();
    ward.innerHTML = data.map(x => `<option value="${x.id}">${x.wardName}</option>`).join('');
  }
  province.addEventListener('change', loadWards);
})();
</script>
}
