@model CleantopiaCRM.Web.Models.Common.PagedResult<CleantopiaCRM.Web.Entities.MaintenanceReminder>
@{
    ViewData["Title"] = "Nhắc bảo trì";
    var customers = ViewBag.Customers as List<CleantopiaCRM.Web.Entities.Customer> ?? new();
    var route = new Dictionary<string, string?>();
    foreach (var key in Context.Request.Query.Keys)
    {
        if (!string.Equals(key, "page", StringComparison.OrdinalIgnoreCase)) route[key] = Context.Request.Query[key].ToString();
    }
}
<div class="d-flex justify-content-between align-items-center mb-3"><h4 class="mb-0">Nhắc bảo trì</h4><a href="/Reminders/Create" class="btn btn-brand"><i class="fa-solid fa-plus"></i> Thêm lịch</a></div>
<form method="get" class="card card-body mb-3"><div class="row g-2"><div class="col-md-3"><input name="q" value="@Model.Query" class="form-control" placeholder="Khách hàng / dịch vụ" /></div><div class="col-md-3"><select name="customerId" class="form-select"><option value="">-- Khách hàng --</option>@foreach(var c in customers){<option value="@c.Id" selected="@(c.Id==(int?)ViewBag.CustomerId)">@c.Name</option>}</select></div><div class="col-md-2"><select name="isDone" class="form-select"><option value="">-- Trạng thái --</option><option value="false" selected="@("false"==(string?)ViewBag.IsDone)">Chờ xử lý</option><option value="true" selected="@("true"==(string?)ViewBag.IsDone)">Đã xử lý</option></select></div><div class="col-md-2"><input type="date" name="dueFrom" value="@ViewBag.DueFrom" class="form-control" /></div><div class="col-md-2"><input type="date" name="dueTo" value="@ViewBag.DueTo" class="form-control" /></div><div class="col-md-12 d-flex gap-2"><button class="btn btn-primary"><i class="fa-solid fa-filter"></i> Lọc</button><a class="btn btn-outline-secondary" href="/Reminders"><i class="fa-solid fa-rotate-left"></i> Đặt lại</a></div></div></form>
<div class="table-responsive"><table class="table table-striped table-bordered align-middle"><thead class="table-light"><tr><th>Khách hàng</th><th>Dịch vụ</th><th>Lần gần nhất</th><th>Nhắc tiếp theo</th><th>Trạng thái</th><th style="width:220px">Thao tác</th></tr></thead><tbody>@foreach(var x in Model.Items){<tr><td>@x.Customer?.Name</td><td>@x.ServiceName</td><td>@x.LastServiceDate.ToString("dd/MM/yyyy")</td><td>@x.NextReminderDate.ToString("dd/MM/yyyy")</td><td>@(x.IsDone ? "Đã xử lý" : "Chờ xử lý")</td><td><a href="/Reminders/Edit/@x.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square"></i></a> <a class="btn btn-sm btn-outline-success" href="/Reminders/MarkDone/@x.Id"><i class="fa-solid fa-check"></i></a> <form method="post" action="/Reminders/Delete/@x.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa nhắc lịch?')"><i class="fa-solid fa-trash"></i></button></form></td></tr>}</tbody></table></div>
@if (Model.TotalPages > 1){<nav><ul class="pagination">@for (var i = 1; i <= Model.TotalPages; i++){<li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-all-route-data="route" asp-route-page="@i">@i</a></li>}</ul></nav>}
